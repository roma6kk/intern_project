.git
.gitignore
.cursor
.vscode
.idea

# Dependencies and build artifacts
**/node_modules
**/.turbo
**/.next
**/dist
**/build
**/coverage
**/.cache
**/.eslintcache
**/*.tsbuildinfo

# Logs and temp files
**/*.log
**/tmp
**/.tmp

# Environment and secrets
.env
**/.env
**/.env.*

# Local Docker/dev files
docker-compose*.yml
Dockerfile*

# Heavy local folders not needed in image context
out
out/**
Rika
Rika/**

# TLS certs are mounted as volumes, never build into images
nginx/certs
nginx/certs/**

# Local runtime/cache data
**/.pytest_cache
**/.mypy_cache
**/prisma/dev.db
**/prisma/dev.db-journal

# OS files
**/.DS_Store
**/Thumbs.db
