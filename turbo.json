{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "globalEnv":[
      "DATABASE_URL",
      "REDIS_URL",
      "RABBITMQ_URL",
      "JWT_ACCESS_SECRET",
      "JWT_REFRESH_SECRET"
    ],
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
        "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    }
  }
}