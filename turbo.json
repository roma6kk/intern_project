{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv":[
    "DATABASE_URL",
    "REDIS_URL",
    "RABBITMQ_URL",
    "JWT_ACCESS_SECRET",
    "JWT_REFRESH_SECRET",
    "ASSISTANT_MICROSERVICE_URL",
    "ASSISTANT_SERVICE_SECRET",
    "LLM_API_KEY",
    "LLM_BASE_URL",
    "LLM_MODEL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WS_URL",
    "NEXT_DEV_HOST",
    "DEV_HOST_IP",
    "AWS_PUBLIC_ENDPOINT",
    "AWS_USE_SIGNED_URLS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
        "dependsOn": ["^build"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:migrate:deploy": {
      "cache": false
    }
  }
}