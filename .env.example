# YANDEX CLOUD S3 (Аналог AWS S3)
AWS_REGION=ru-central1-d # Стандартный регион Yandex
AWS_ACCESS_KEY_ID=AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=AWS_SECRET_ACCESS_KEY
AWS_BUCKET_NAME=innogram-bucket
# For cloud S3 (Yandex Cloud): https://storage.yandexcloud.net
# For local MinIO from Docker container: http://host.docker.internal:9000
AWS_ENDPOINT=https://storage.yandexcloud.net
# Public URL that clients use to open uploaded files.
# For local HTTPS via nginx proxy: https://api.local
AWS_PUBLIC_ENDPOINT=https://storage.yandexcloud.net
# true for private buckets with signed links; false for public bucket direct links
AWS_USE_SIGNED_URLS=true

