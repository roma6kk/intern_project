{
  "name": "intern_project",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo dev --parallel",
    "lint": "turbo run lint -- --fix",
    "db:generate": "turbo db:generate",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "next": "16.1.4",
    "@eslint/js": "^9.39.1",
    "@types/react-mentions": "^4.4.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.6.2",
    "turbo": "^2.6.3",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.48.1"
  },
  "overrides": {
    "next": "16.1.4",
    "@next/env": "16.1.4",
    "@next/swc-darwin-arm64": "16.1.4",
    "@next/swc-darwin-x64": "16.1.4",
    "@next/swc-linux-arm64-gnu": "16.1.4",
    "@next/swc-linux-arm64-musl": "16.1.4",
    "@next/swc-linux-x64-gnu": "16.1.4",
    "@next/swc-linux-x64-musl": "16.1.4",
    "@next/swc-win32-arm64-msvc": "16.1.4",
    "@next/swc-win32-x64-msvc": "16.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
